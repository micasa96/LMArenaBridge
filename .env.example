# Puerto en el que se ejecutará la aplicación (por defecto 8000)
PORT=8000

# Contraseña para el panel de administración (por defecto "admin")
# IMPORTANTE: Cambia esta contraseña en producción
ADMIN_PASSWORD=admin

# Deshabilitar el proxy de userscript (por defecto false)
LM_BRIDGE_DISABLE_USERSCRIPT_PROXY=false

# Ruta al archivo de configuración (por defecto config.json)
# CONFIG_FILE=config.json

# Ruta al archivo de modelos (por defecto models.json)
# MODELS_FILE=models.json

# Modo debug (por defecto true en el código fuente)
# DEBUG=true